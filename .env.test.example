# Test target configuration — copy to .env.test and fill in values.
# .env.test is gitignored.

# Deployment URL passed to `vercel curl --deployment` (no trailing slash)
DEPLOYMENT="https://your-app.vercel.app"

# Master admin token (REMINDER_ADMIN_TOKEN on the server)
ADMIN_TOKEN="change-me"

# Vercel deployment protection bypass secret (set in Vercel project settings)
VERCEL_BYPASS_TOKEN=""

# Telegram user IDs used as test subjects (integers)
TEST_USER_ID="111111111"
USER_ID_B="222222222"
